{
  "rules": {
    ".read": false,
    ".write": false,
    "rooms": {
      "$room": {
        ".read": true,
        ".write": true,
        "messages": {
          ".indexOn": "t",
          "$msg": {
            ".validate": "newData.hasChildren(['n', 'x', 't']) && newData.child('n').isString() && newData.child('n').val().length <= 20 && newData.child('x').isString() && newData.child('x').val().length <= 200"
          }
        }
      }
    }
  }
}
